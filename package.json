{
  "name": "spps-app",
  "private": true,
  "version": "2.0.0",
  "description": "Sport Psychology Practitioner Suite — HIPAA-compliant practice management",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:api": "node --watch server/src/index.js",
    "start:api": "node server/src/index.js",
    "build": "vite build",
    "build:full": "npm run type-check && npm run lint && npm run build && npm run verify:server && npm run smoke",
    "preview": "vite preview",
    "lint": "eslint \"src/**/*.{ts,tsx}\" \"api/**/*.js\" \"server/src/**/*.js\" --report-unused-disable-directives",
    "type-check": "tsc --noEmit",
    "verify:server": "node scripts/verify-server.mjs",
    "smoke": "node scripts/smoke-checks.mjs",
    "ci": "npm run build:full"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.49.1",
    "@tanstack/react-query": "^5.17.0",
    "clsx": "^2.1.0",
    "cors": "^2.8.5",
    "date-fns": "^3.2.0",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "helmet": "^8.0.0",
    "json2csv": "^6.0.0-alpha.2",
    "lucide-react": "^0.309.0",
    "mammoth": "^1.12.0",
    "morgan": "^1.10.0",
    "nodemailer": "^8.0.6",
    "pg": "^8.13.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.21.0",
    "recharts": "^2.10.0",
    "socket.io": "^4.8.1",
    "socket.io-client": "^4.8.1",
    "zod": "^3.23.8",
    "zustand": "^4.4.7"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^25.5.2",
    "@types/react": "^18.2.43",
    "@types/react-dom": "^18.2.17",
    "@typescript-eslint/eslint-plugin": "^8.58.0",
    "@typescript-eslint/parser": "^8.58.0",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.4.16",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.5.0",
    "postcss": "^8.5.10",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.2.2",
    "typescript-eslint": "^8.59.0",
    "vite": "^8.0.3"
  }
}
