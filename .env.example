# Frontend
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key
VITE_API_BASE_URL=http://localhost:4000
VITE_GROQ_API_KEY=your-groq-api-key

# Backend core
PORT=4000
API_BASE_PATH=/api
CLIENT_ORIGIN=http://localhost:5173
DATABASE_URL=postgresql://postgres:password@db.your-project.supabase.co:5432/postgres
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Platform defaults
PLATFORM_COUNTRY=IN
PLATFORM_CURRENCY=INR
SESSION_TOKEN_COST=10
MESSAGE_TOKEN_COST=1

# Email / athlete activation
ENABLE_ACTIVATION_EMAIL=true
SMTP_HOST=smtp.resend.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=resend
SMTP_PASS=your-smtp-or-resend-api-key
SMTP_FROM=SPPS <no-reply@yourdomain.com>

# Stripe
STRIPE_SECRET_KEY=sk_live_or_test
STRIPE_WEBHOOK_SECRET=whsec_...

# Razorpay
RAZORPAY_KEY_ID=rzp_test_or_live
RAZORPAY_KEY_SECRET=your-razorpay-secret
RAZORPAY_WEBHOOK_SECRET=your-razorpay-webhook-secret

# Clinical audit
CLINICAL_AUDIT_SALT=replace-with-a-long-random-secret
